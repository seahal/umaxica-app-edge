{
  "name": "umaxica-apps-edge-com-apex",
  "type": "module",
  "scripts": {
    "server": "vite",
    "build": "vite build --ssr src/index.tsx && rm -rf dist/client && mkdir -p dist/client && cp -a public/. dist/client/",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "deploy:upload": "$npm_execpath run build && wrangler versions upload",
    "deploy:promote": "wrangler versions deploy --yes",
    "cf-typegen": "pnpm wrangler types --env-interface CloudflareBindings",
    "type": "pnpm run cf-typegen && pnpm exec tsgo --noEmit"
  },
  "dependencies": {
    "@sentry/cloudflare": "^10.40.0",
    "hono": "^4.12.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.25.6",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.1.17",
    "vite": "8.0.0-beta.16",
    "vite-ssr-components": "^0.5.1",
    "wrangler": "^4.69.0"
  }
}
