{
  "name": "umaxica-apps-edge-org-apex",
  "type": "module",
  "scripts": {
    "server": "vp dev",
    "build": "vp build && mkdir -p dist/client/src && find dist/client/assets -name 'style-*.css' -exec cp {} dist/client/src/style.css \\;",
    "preview": "$npm_execpath run build && vp preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "deploy:upload": "$npm_execpath run build && wrangler versions upload",
    "deploy:promote": "wrangler versions deploy --yes",
    "cf-typegen": "pnpm wrangler types --env-interface CloudflareBindings",
    "type": "pnpm run cf-typegen && vp exec tsc --noEmit"
  },
  "dependencies": {
    "@hono/otel": "^1.1.1",
    "@sentry/cloudflare": "^10.40.0",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/react": "catalog:",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vite-ssr-components": "^0.5.2",
    "wrangler": "catalog:"
  }
}
